{
  "name": "unocss-merge",
  "type": "module",
  "version": "0.10.0",
  "packageManager": "pnpm@11.5.2+sha512.71c631e382066efc25625d5cf029075de07b61b37f6e27350fbd84b1bda5864c8c1967adc280776b45c30a715c0359a3be08fef42d5bb09e2b99029979692916",
  "description": "simple utility to merge unocss class names",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/unocss-merge#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/unocss-merge.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/unocss-merge/issues"
  },
  "keywords": [
    "unocss-merge",
    "unocss",
    "merge",
    "tw-merge"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./memoize": {
      "types": "./dist/memoize.d.ts",
      "default": "./dist/memoize.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:dev": "vitest",
    "test-cover": "vitest run --coverage",
    "prepublishOnly": "pnpm typecheck && pnpm test-cover && pnpm build"
  },
  "peerDependencies": {
    "memoize": "^11.0.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "memoize": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@magicdawn/eslint-config": "^1.6.6",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/react": "^19.2.16",
    "@vitest/coverage-v8": "^4.1.8",
    "es-toolkit": "^1.47.0",
    "eslint": "^10.4.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.3",
    "tsdown": "^0.22.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "lint-staged": {
    "*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
