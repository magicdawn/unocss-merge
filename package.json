{
  "name": "unocss-merge",
  "type": "module",
  "version": "0.9.0",
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "description": "simple utility to merge unocss class names",
  "author": "magicdawn",
  "license": "MIT",
  "homepage": "https://github.com/magicdawn/unocss-merge#readme",
  "repository": {
    "type": "git",
    "url": "git+ssh://git@github.com/magicdawn/unocss-merge.git"
  },
  "bugs": {
    "url": "https://github.com/magicdawn/unocss-merge/issues"
  },
  "keywords": [
    "unocss-merge",
    "unocss",
    "merge",
    "tw-merge"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "default": "./dist/react.js"
    },
    "./memoize": {
      "types": "./dist/memoize.d.ts",
      "default": "./dist/memoize.js"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/"
  ],
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "scripts": {
    "prepare": "husky",
    "dev": "tsdown --watch",
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:dev": "vitest",
    "test-cover": "vitest run --coverage",
    "prepublishOnly": "pnpm typecheck && pnpm test-cover && pnpm build"
  },
  "peerDependencies": {
    "memoize": "^10.2.0",
    "react": ">=18"
  },
  "peerDependenciesMeta": {
    "memoize": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "clsx": "^2.1.1"
  },
  "devDependencies": {
    "@magicdawn/eslint-config": "^1.6.2",
    "@magicdawn/prettier-config": "^0.1.0",
    "@types/react": "^19.2.14",
    "@vitest/coverage-v8": "^4.1.2",
    "es-toolkit": "^1.45.1",
    "eslint": "^10.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tsdown": "^0.21.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "eslint --fix",
      "prettier --write"
    ],
    "!*.{?(c|m)(j|t)s?(x),json,y?(a)ml}": [
      "prettier --write --ignore-unknown"
    ]
  }
}
